# Personal data (user fills these)
data/applications.md
# pipeline.md and scan-history.tsv are tracked for remote scan trigger state persistence
reports/*.md
!reports/.gitkeep
output/*
!output/.gitkeep
batch/logs/*
!batch/logs/.gitkeep
batch/batch-state.tsv
batch/batch-input.tsv
batch/tracker-additions/*.tsv
!batch/tracker-additions/.gitkeep
jds/*
!jds/.gitkeep

# User config — tracked so remote scan trigger can read them
# (profile.yml, portals.yml, _profile.md intentionally committed to this fork)
.update-dismissed
.update-lock

# Generated
.resolved-prompt-*
node_modules/
bun.lock

